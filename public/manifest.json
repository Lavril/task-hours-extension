{
  "manifest_version": 3,
  "name": "Task Hours Tracker",
  "version": "1.0.0",

  "description": "Task hours management extension",

  "action": {
    "default_title": "Task Hours Tracker"
  },

  "chrome_url_overrides": {},

  "permissions": ["storage"],

  "host_permissions": [],

  "icons": {},

  "web_accessible_resources": [
    {
      "resources": ["*"],
      "matches": ["<all_urls>"]
    }
  ]
}